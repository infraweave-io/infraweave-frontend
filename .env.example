# Backend API
REACT_APP_API_URL=https://your-api-id.execute-api.us-west-2.amazonaws.com

# OAuth providers (JSON array — one entry per IdP).
# Each provider needs at least: id, clientId, and either (type=cognito + domain)
# or (authorizationEndpoint + tokenEndpoint). See AUTH_SETUP.md for full schema
# and IdP-specific examples (Cognito, Okta, Auth0, Azure AD, Keycloak, ...).
REACT_APP_OAUTH_PROVIDERS=[{"id":"aws","type":"cognito","displayName":"AWS","domain":"your-domain.auth.us-west-2.amazoncognito.com","clientId":"your-client-id","icon":"cloud"}]
