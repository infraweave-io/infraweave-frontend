{
  "name": "@infraweave/frontend",
  "version": "0.0.9",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public",
    "main": "dist/index.js",
    "types": "dist/index.d.ts"
  },
  "keywords": [
    "frontend",
    "infraweave"
  ],
  "scripts": {
    "start": "vite",
    "start:mock": "vite --mode mock",
    "start:real": "vite build --mode real && vite preview --mode real",
    "build": "vite build",
    "build:types": "tsc -p tsconfig.json",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:screenshots": "node scripts/screenshot-report.js && open playwright-screenshots.html",
    "test:e2e:screenshots:pdf": "node scripts/screenshot-report.js --pdf",
    "tsc": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@microlink/react-json-view": "^1.31.18",
    "@monaco-editor/react": "^4.7.0",
    "@mui/icons-material": "^7.3.10",
    "@mui/material": "^7.3.10",
    "@mui/styles": "^6.3.0",
    "@mui/x-charts": "^8.28.2",
    "@mui/x-tree-view": "^7.22.0",
    "@types/jszip": "^3.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@uiw/react-codemirror": "^4.25.9",
    "@xyflow/react": "^12.10.2",
    "camelcase": "^6.3.0",
    "elkjs": "^0.11.1",
    "jszip": "^3.10.1",
    "msw": "^2.13.4",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.16.0",
    "react-syntax-highlighter": "^15.6.1",
    "react-use": "^17.2.4",
    "remark-gfm": "^4.0.1",
    "vscode-diff": "^3.0.1"
  },
  "peerDependencies": {
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.3",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/react-syntax-highlighter": "^15",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "happy-dom": "^20.9.0",
    "postcss": "^8.5.10",
    "react": "^19.2.5",
    "tailwindcss": "^4.2.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.59.0",
    "vite": "^6.4.2",
    "vitest": "^4.1.5"
  },
  "files": [
    "dist"
  ],
  "msw": {
    "workerDirectory": "public"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
